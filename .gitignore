# Codex — never commit credentials or session history
.codex/auth.json
.codex/sessions/
.codex/logs/
.codex/skills/gsap-core/
.codex/skills/gsap-frameworks/
.codex/skills/gsap-performance/
.codex/skills/gsap-plugins/
.codex/skills/gsap-react/
.codex/skills/gsap-scrolltrigger/
.codex/skills/gsap-timeline/
.codex/skills/gsap-utils/

# Claude Code — never commit local settings with potential secrets
.claude/settings.local.json

# VS Code - keep shared workspace config, ignore personal machine files
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json

# Env files
.env
.env.*
.dev.vars

# Dependencies
node_modules/

# Build outputs
.next/
dist/
output/

# Local tool/runtime artifacts
.partykit/
.playwright-cli/
.playwright-mcp/
.superpowers/
docs/superpowers/
*.tsbuildinfo
*.log
debug.log

# Local backups
*.backup-*/

# Turborepo
.turbo/

# Local git worktrees
.worktrees/
