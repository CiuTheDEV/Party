{
  "name": "party",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "dev.bat",
    "lint": "turbo lint",
    "verify:encoding": "npm run encoding:check && npm run docs:check-encoding",
    "encoding:check": "powershell -ExecutionPolicy Bypass -File ./scripts/check-text-encoding.ps1",
    "docs:normalize": "powershell -ExecutionPolicy Bypass -File ./scripts/normalize-markdown.ps1",
    "docs:check-encoding": "powershell -ExecutionPolicy Bypass -File ./scripts/check-markdown-encoding.ps1"
  },
  "devDependencies": {
    "turbo": "^2.8.20"
  },
  "packageManager": "npm@11.12.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/games/*"
  ]
}
