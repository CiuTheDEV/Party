# Normalize text files by default
* text=auto

# Keep source, config, and docs on LF in the repository
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.svg text eol=lf
*.sh text eol=lf

# Windows-native script files should stay CRLF in the working tree
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Keep Codex config normalized; auth should be ignored in .gitignore, not here
.codex/config.toml text eol=lf
